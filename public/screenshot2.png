<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="630" fill="#f8f9fa"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="1200" height="80" fill="#ffffff" stroke="#e9ecef" stroke-width="1"/>
  
  <!-- Title -->
  <text x="600" y="50" text-anchor="middle" fill="#ff69b4" font-family="Arial, sans-serif" font-size="32" font-weight="bold">📊 Bodycount Scores</text>
  
  <!-- Tab navigation -->
  <rect x="200" y="100" width="800" height="50" fill="#ffffff" stroke="#e9ecef" stroke-width="1" rx="8"/>
  
  <!-- Overview tab -->
  <rect x="220" y="110" width="120" height="30" rx="6" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="280" y="130" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">Overview</text>
  
  <!-- Leaderboard tab (active) -->
  <rect x="360" y="110" width="120" height="30" rx="6" fill="#ff69b4"/>
  <text x="420" y="130" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="14" font-weight="bold">Leaderboard</text>
  
  <!-- Breakdown tab -->
  <rect x="500" y="110" width="120" height="30" rx="6" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="560" y="130" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">Breakdown</text>
  
  <!-- Leaderboard entries -->
  
  <!-- Entry 1: Rihanna -->
  <rect x="150" y="180" width="900" height="80" fill="#ffffff" stroke="#ff69b4" stroke-width="2" rx="10"/>
  <!-- Medal -->
  <circle cx="200" cy="220" r="20" fill="#ffd700"/>
  <text x="200" y="228" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">🥇</text>
  <!-- Profile image placeholder -->
  <circle cx="260" cy="220" r="25" fill="#e9ecef" stroke="#dee2e6" stroke-width="2"/>
  <text x="260" y="228" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="20">👤</text>
  <!-- Name and status -->
  <text x="310" y="215" fill="#212529" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Rihanna</text>
  <text x="310" y="235" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">New</text>
  <!-- Score -->
  <text x="950" y="215" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="32" font-weight="bold">0</text>
  <text x="950" y="235" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="12">connections</text>
  
  <!-- Entry 2: Cara Delevingne -->
  <rect x="150" y="280" width="900" height="80" fill="#ffffff" stroke="#dee2e6" stroke-width="1" rx="10"/>
  <!-- Medal -->
  <circle cx="200" cy="320" r="20" fill="#c0c0c0"/>
  <text x="200" y="328" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">🥈</text>
  <!-- Profile image placeholder -->
  <circle cx="260" cy="320" r="25" fill="#e9ecef" stroke="#dee2e6" stroke-width="2"/>
  <text x="260" y="328" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="20">👤</text>
  <!-- Name and status -->
  <text x="310" y="315" fill="#212529" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Cara</text>
  <text x="310" y="330" fill="#212529" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Delevingne</text>
  <text x="310" y="345" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">New</text>
  <!-- Score -->
  <text x="950" y="315" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="32" font-weight="bold">0</text>
  <text x="950" y="335" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="12">connections</text>
  
  <!-- Entry 3: Amber Heard -->
  <rect x="150" y="380" width="900" height="80" fill="#ffffff" stroke="#dee2e6" stroke-width="1" rx="10"/>
  <!-- Medal -->
  <circle cx="200" cy="420" r="20" fill="#cd7f32"/>
  <text x="200" y="428" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">🥉</text>
  <!-- Profile image placeholder -->
  <circle cx="260" cy="420" r="25" fill="#e9ecef" stroke="#dee2e6" stroke-width="2"/>
  <text x="260" y="428" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="20">👤</text>
  <!-- Name and status -->
  <text x="310" y="415" fill="#212529" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Amber Heard</text>
  <text x="310" y="435" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">New</text>
  <!-- Score -->
  <text x="950" y="415" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="32" font-weight="bold">0</text>
  <text x="950" y="435" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="12">connections</text>
  
  <!-- Entry 4: Jennifer Gwynne -->
  <rect x="150" y="480" width="900" height="80" fill="#ffffff" stroke="#dee2e6" stroke-width="1" rx="10"/>
  <!-- Rank number -->
  <circle cx="200" cy="520" r="20" fill="#6c757d"/>
  <text x="200" y="528" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">4</text>
  <!-- Profile image placeholder -->
  <circle cx="260" cy="520" r="25" fill="#e9ecef" stroke="#dee2e6" stroke-width="2"/>
  <text x="260" y="528" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="20">👤</text>
  <!-- Name and status -->
  <text x="310" y="515" fill="#212529" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Jennifer</text>
  <text x="310" y="530" fill="#212529" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Gwynne</text>
  <text x="310" y="545" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">New</text>
  <!-- Score -->
  <text x="950" y="515" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="32" font-weight="bold">0</text>
  <text x="950" y="535" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="12">connections</text>
</svg>