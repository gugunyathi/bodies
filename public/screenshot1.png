<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="630" fill="#f8f9fa"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="1200" height="80" fill="#ffffff" stroke="#e9ecef" stroke-width="1"/>
  
  <!-- Swipe button -->
  <rect x="30" y="20" width="120" height="40" rx="20" fill="#e91e63"/>
  <text x="90" y="44" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">🔥 Swipe</text>
  
  <!-- Add button -->
  <rect x="170" y="20" width="80" height="40" rx="8" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="210" y="44" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="16">+ Add</text>
  
  <!-- Scores tab -->
  <rect x="270" y="20" width="80" height="40" rx="8" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="310" y="44" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="16">📊 Scores</text>
  
  <!-- Privacy tab -->
  <rect x="370" y="20" width="80" height="40" rx="8" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="410" y="44" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="16">🔒 Privacy</text>
  
  <!-- Bodies title -->
  <text x="600" y="140" text-anchor="middle" fill="#e91e63" font-family="Arial, sans-serif" font-size="48" font-weight="bold">Bodies</text>
  
  <!-- Subtitle -->
  <text x="600" y="180" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="18">Rate relationships - Track scores - Keep it real</text>
  
  <!-- Progress indicator -->
  <text x="50" y="220" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">1 of 27</text>
  <rect x="1100" y="200" width="60" height="20" rx="10" fill="#e91e63"/>
  <text x="1130" y="214" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12" font-weight="bold">4%</text>
  
  <!-- Main card -->
  <rect x="100" y="260" width="1000" height="320" rx="20" fill="#2c2c2c" stroke="#444" stroke-width="2"/>
  
  <!-- Card content background -->
  <rect x="130" y="290" width="940" height="260" rx="15" fill="#f8f9fa"/>
  
  <!-- Card title -->
  <text x="600" y="330" text-anchor="middle" fill="#212529" font-family="Arial, sans-serif" font-size="24" font-weight="bold">Rate Elon Musk</text>
  
  <!-- Question -->
  <text x="600" y="365" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="16">How would you categorize the relationship</text>
  <text x="600" y="385" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="16">with Rihanna?</text>
  
  <!-- Option buttons -->
  <!-- Dated option -->
  <rect x="200" y="420" width="120" height="60" rx="10" fill="#ffffff" stroke="#dee2e6" stroke-width="1"/>
  <text x="260" y="440" text-anchor="middle" font-size="24">❤️</text>
  <text x="260" y="465" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="14" font-weight="bold">Dated</text>
  
  <!-- Hookup option -->
  <rect x="340" y="420" width="120" height="60" rx="10" fill="#ffffff" stroke="#dee2e6" stroke-width="1"/>
  <text x="400" y="440" text-anchor="middle" font-size="24">🔥</text>
  <text x="400" y="465" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="14" font-weight="bold">Hookup</text>
  
  <!-- Transactional option -->
  <rect x="480" y="420" width="120" height="60" rx="10" fill="#ffffff" stroke="#dee2e6" stroke-width="1"/>
  <text x="540" y="440" text-anchor="middle" font-size="24">💵</text>
  <text x="540" y="465" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="14" font-weight="bold">Transactional</text>
  
  <!-- Add Evidence button -->
  <rect x="650" y="420" width="200" height="40" rx="20" fill="#4285f4"/>
  <text x="750" y="444" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">🔗 Add Evidence</text>
  
  <!-- Evidence section -->
  <text x="200" y="510" fill="#6c757d" font-family="Arial, sans-serif" font-size="16" font-weight="bold">Evidence (Optional)</text>
  <text x="950" y="510" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">0 items added</text>
  
  <!-- No evidence placeholder -->
  <rect x="200" y="520" width="700" height="20" rx="2" fill="#e9ecef"/>
</svg>