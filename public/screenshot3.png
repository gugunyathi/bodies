<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="630" fill="#f8f9fa"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="1200" height="80" fill="#ffffff" stroke="#e9ecef" stroke-width="1"/>
  
  <!-- Swipe button -->
  <rect x="30" y="20" width="120" height="40" rx="20" fill="#e91e63"/>
  <text x="90" y="44" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">🔥 Swipe</text>
  
  <!-- Add button -->
  <rect x="170" y="20" width="80" height="40" rx="8" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="210" y="44" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="16">+ Add</text>
  
  <!-- Scores tab -->
  <rect x="270" y="20" width="80" height="40" rx="8" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="310" y="44" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="16">📊 Scores</text>
  
  <!-- Privacy tab -->
  <rect x="370" y="20" width="80" height="40" rx="8" fill="#f8f9fa" stroke="#dee2e6" stroke-width="1"/>
  <text x="410" y="44" text-anchor="middle" fill="#495057" font-family="Arial, sans-serif" font-size="16">🔒 Privacy</text>
  
  <!-- Bodies title -->
  <text x="600" y="140" text-anchor="middle" fill="#e91e63" font-family="Arial, sans-serif" font-size="48" font-weight="bold">Bodies</text>
  
  <!-- Subtitle -->
  <text x="600" y="180" text-anchor="middle" fill="#6c757d" font-family="Arial, sans-serif" font-size="18">Rate relationships - Track scores - Keep it real</text>
  
  <!-- Progress indicator -->
  <text x="50" y="220" fill="#6c757d" font-family="Arial, sans-serif" font-size="14">1 of 27</text>
  <rect x="1100" y="200" width="60" height="20" rx="10" fill="#e91e63"/>
  <text x="1130" y="214" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12" font-weight="bold">4%</text>
  
  <!-- Main profile card -->
  <rect x="100" y="260" width="1000" height="320" rx="20" fill="#2c2c2c" stroke="#444" stroke-width="2"/>
  
  <!-- Profile image area -->
  <rect x="130" y="290" width="940" height="200" rx="15" fill="url(#profileGradient)"/>
  
  <!-- Gradient definition -->
  <defs>
    <linearGradient id="profileGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff6b9d;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#c44569;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Body count stats overlay -->
  <rect x="900" y="310" width="150" height="80" rx="10" fill="rgba(0,0,0,0.7)"/>
  <text x="975" y="330" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12" font-weight="bold">BodyCount: 4</text>
  <text x="975" y="350" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12" font-weight="bold">Confirmed: 4</text>
  <text x="975" y="370" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="12" font-weight="bold">Rumored: 0</text>
  
  <!-- Connection avatars -->
  <circle cx="1020" cy="340" r="15" fill="#ffd700" stroke="white" stroke-width="2"/>
  <text x="1020" y="346" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="10" font-weight="bold">EM</text>
  
  <circle cx="1020" cy="370" r="15" fill="#ff69b4" stroke="white" stroke-width="2"/>
  <text x="1020" y="376" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="8" font-weight="bold">ASAP</text>
  
  <circle cx="1020" cy="400" r="15" fill="#32cd32" stroke="white" stroke-width="2"/>
  <text x="1020" y="406" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="8" font-weight="bold">Chris</text>
  
  <circle cx="1020" cy="430" r="15" fill="#ff4500" stroke="white" stroke-width="2"/>
  <text x="1020" y="436" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="8" font-weight="bold">Drake</text>
  
  <!-- Profile info section -->
  <rect x="130" y="500" width="940" height="70" rx="15" fill="#ffffff"/>
  
  <!-- Profile name and details -->
  <text x="160" y="530" fill="#212529" font-family="Arial, sans-serif" font-size="24" font-weight="bold">Rihanna, 36</text>
  <text x="160" y="550" fill="#6c757d" font-family="Arial, sans-serif" font-size="16">Barbadian singer, actress, and businesswoman.</text>
  <text x="160" y="565" fill="#6c757d" font-family="Arial, sans-serif" font-size="16">Global superstar known for hits like "Umbrella" an...</text>
  
  <!-- Social handles -->
  <text x="600" y="530" fill="#e91e63" font-family="Arial, sans-serif" font-size="14">@@badgalriri</text>
  <text x="720" y="530" fill="#1da1f2" font-family="Arial, sans-serif" font-size="14">@@rihanna</text>
  
  <!-- Rate button -->
  <rect x="750" y="540" width="200" height="40" rx="20" fill="#e91e63"/>
  <text x="850" y="564" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">⭐ Rate This Person</text>
</svg>